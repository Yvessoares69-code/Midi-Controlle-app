import 'package:flutter_midi_command/flutter_midi_command.dart';

class MidiManager {
  final MidiCommand _midiCommand = MidiCommand();

  // Escaneia dispositivos (Bluetooth/USB)
  Future<List<MidiDevice>> getDevices() async {
    return await _midiCommand.devices;
  }

  // Conecta ao dispositivo escolhido
  void connect(MidiDevice device) {
    _midiCommand.connectToDevice(device);
  }

  // Envia um comando de CC (Control Change)
  // cc: número do controle (ex: 7 para volume)
  // value: valor (0 a 127)
  void sendCC(int cc, int value) {
    _midiCommand.sendData([0xB0, cc, value]);
  }
}
import 'package:flutter_midi_command/flutter_midi_command.dart';

class MidiManager {
  final MidiCommand _midiCommand = MidiCommand();

  // Envia valores contínuos (Faders e Knobs)
  void sendCC(int cc, int value) {
    // 0xB0 = Control Change, Canal 1
    _midiCommand.sendData([0xB0, cc, value]);
  }

  // Dispara notas (Pads - Bateria/Samples)
  // note: número da nota (0-127)
  // velocity: força do toque (0-127)
  void sendNote(int note, int velocity) {
    // 0x90 = Note On, Canal 1
    // 0x80 = Note Off, Canal 1
    if (velocity > 0) {
      _midiCommand.sendData([0x90, note, velocity]);
    } else {
      _midiCommand.sendData([0x80, note, 0]);
    }
  }

  // Verifica se o dispositivo está pronto para enviar dados
  Future<bool> isConnected() async {
    var devices = await _midiCommand.connectedDevices;
    return devices != null && devices.isNotEmpty;
  }
}
